Options -Indexes -MultiViews
DirectoryIndex index
AddDefaultCharset UTF-8
AddType font/woff2 .woff2

<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteCond %{HTTP_HOST} ^www\.vevolt\.app$ [NC]
  RewriteRule ^ https://vevolt.app%{REQUEST_URI} [R=301,L,NE]

  RewriteCond %{THE_REQUEST} \s/+index(?:[?\s]) [NC]
  RewriteRule ^index$ / [R=301,L]
  RewriteCond %{THE_REQUEST} \s+/(en|es)/index(?:[?\s]) [NC]
  RewriteRule ^(en|es)/index$ /$1/ [R=301,L]

  RewriteRule ^vevolt/assets/(.*)$ /assets/$1 [R=301,L]
  RewriteRule ^vevolt/termos$ /termos [R=301,L]
  RewriteRule ^vevolt/politica$ /politica [R=301,L]
  RewriteRule ^vevolt/?$ / [R=301,L]

  RewriteRule ^tester-signup$ tester-signup.php [L]
</IfModule>

<Files "tester-signup.php">
  Require all granted
</Files>

<FilesMatch "^(index|termos|politica|terms|privacy|terminos|privacidad)$">
  ForceType text/html
</FilesMatch>

<IfModule mod_headers.c>
  Header always unset X-Powered-By
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

  <FilesMatch "^index$">
    Header onsuccess unset Cache-Control
    Header always unset Cache-Control
    Header always set Cache-Control "public, max-age=0, must-revalidate"
    Header always set CDN-Cache-Control "public, max-age=300"
    Header always set Cloudflare-CDN-Cache-Control "public, max-age=300"
  </FilesMatch>

  <FilesMatch "^(termos|politica|terms|privacy|terminos|privacidad)$">
    Header always set X-Robots-Tag "noindex, nofollow"
    Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header always set CDN-Cache-Control "no-store"
    Header always set Cloudflare-CDN-Cache-Control "no-store"
  </FilesMatch>

  <FilesMatch "\.(?:css|js|png|webp|ico|woff2)$">
    Header always set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/manifest+json "access plus 1 day"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json application/manifest+json application/xml image/svg+xml
</IfModule>

