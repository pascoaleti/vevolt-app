    <string name="privacy_summary_title">Summary</string>
    <string name="privacy_summary_body">VeVolt works without an email/password login. Location is optional. The secure backend validates Google Play Premium and stores VeVolt Condo data only when that feature is used.</string>
    <string name="privacy_device_title">Data on this device</string>
    <string name="privacy_device_body">The app locally saves vehicle details, onboarding state, saved locations and charging records from this device.</string>
    <string name="privacy_collection_title">Collection and sharing</string>
    <string name="privacy_collection_body">Personal vehicle records stay local. Location can be sent to Open Charge Map. VeVolt Condo sends membership, reservations and shared charging records to VeVolt when enabled.</string>
    <string name="privacy_payments_title">Payments</string>
    <string name="privacy_payments_body">Google Play processes payment. VeVolt verifies the subscription server-side and stores only hashed identifiers, status and expiry with automatic retention limits.</string>
